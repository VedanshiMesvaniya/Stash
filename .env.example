# Copy this file to .env and fill in the values below.
# Never commit the real .env file.

# REQUIRED — app will not start without this.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Leave blank for local development (uses a local SQLite file automatically).
# In production, set this to your Neon/Postgres connection string.
DATABASE_URL=

# LLM providers for the chat parser. The app works without these (chat
# messages just get queued and retried later), but you need at least one
# for the AI parsing to actually happen.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# development | production — production enables HTTPS-only session cookies,
# so only set this to "production" once you're actually serving over HTTPS.
ENVIRONMENT=development

# How often (seconds) the background job retries any chat messages that
# failed because both LLM providers were down. Default is fine for most.
PENDING_RETRY_INTERVAL_SECONDS=300

# Used in one outgoing LLM request header. Fine to leave as-is locally.
APP_PUBLIC_URL=https://stash.local
